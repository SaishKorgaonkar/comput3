# ── Database ───────────────────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=postgres://comput3:comput3secret@localhost:5432/comput3

# Password for the postgres container (docker-compose default: comput3secret)
POSTGRES_PASSWORD=comput3secret

# ── Auth ───────────────────────────────────────────────────────────────────
# Random 32-byte hex string used to sign JWTs — CHANGE THIS
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# ── Chain / RPC ────────────────────────────────────────────────────────────
# Base Sepolia RPC endpoint
RPC_URL=https://sepolia.base.org

# Funded deployer private key (no 0x prefix needed)
PRIVATE_KEY=

# ── Deployed contract addresses (fill after `scripts/deploy-contracts.sh`) ─
PROVIDER_REGISTRY_ADDRESS=
DEPLOYMENT_ESCROW_ADDRESS=
JOB_AUCTION_ADDRESS=

# ── EAS (Ethereum Attestation Service) ────────────────────────────────────
# Base Sepolia EAS contract (already deployed by EAS team — default below)
EAS_CONTRACT_ADDRESS=0x4200000000000000000000000000000000000021

# Fill after `scripts/register-eas-schema.sh`
EAS_SCHEMA_UID=

# ── AI / Scanner ───────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── 0G Storage ────────────────────────────────────────────────────────────
ZEROG_API_URL=https://evmrpc-testnet.0g.ai
ZEROG_PRIVATE_KEY=

# ── Docker ────────────────────────────────────────────────────────────────
# Override when using a remote Docker daemon (docker-in-docker container)
DOCKER_HOST=tcp://localhost:2375

# ── Frontend (Next.js) ────────────────────────────────────────────────────
# URL the browser uses to reach the backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8080

# WalletConnect / RainbowKit project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
