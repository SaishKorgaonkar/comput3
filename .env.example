# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=add_ur_database_url
POSTGRES_PASSWORD=add_ur_password

# ── Auth ───────────────────────────────────────────────────────────────────
# Random 64-char hex string — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_64_char_hex_string
VAULT_MASTER_SECRET=change_me_to_a_different_random_64_char_hex_string

# ── AI / Claude ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-5
SCAN_MODEL=claude-3-5-haiku-20241022

# ── Chain / RPC ────────────────────────────────────────────────────────────
ETH_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Deployer wallet — used by scripts/deploy-contracts.sh and scripts/register-provider.sh
DEPLOYER_PRIVATE_KEY=

# Agent wallet — used by the backend for on-chain operations (EAS attestations, etc.)
AGENT_WALLET_PRIVATE_KEY=

# ── Deployed contract addresses (fill after scripts/deploy-contracts.sh) ───
PROVIDER_REGISTRY_ADDRESS=
DEPLOYMENT_ESCROW_ADDRESS=
JOB_AUCTION_ADDRESS=

# ── EAS (Ethereum Attestation Service) ─────────────────────────────────────
# EAS on Ethereum Sepolia
EAS_CONTRACT_ADDRESS=0xC2679fBD37d54388Ce493F1DB75320D236e1815e
# Fill after scripts/register-eas-schema.sh
EAS_SCHEMA_UID=

# ── 0G Network — decentralized agent memory ─────────────────────────────────
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_PRIVATE_KEY=
ZG_FLOW_ADDRESS=

# ── Gensyn AXL — cross-node agent messaging ────────────────────────────────
AXL_ENDPOINT=
AXL_PRIVATE_KEY=

# ── KeeperHub — on-chain execution reliability ─────────────────────────────
KEEPERHUB_ENDPOINT=
KEEPERHUB_PRIVATE_KEY=

# ── Provider mode (for nodes that act as compute providers) ────────────────
# Set PROVIDER_MODE=true on provider nodes; they will auto-watch and bid on job auctions.
PROVIDER_MODE=false
# Provider's own registered wallet private key (different from AGENT_WALLET_PRIVATE_KEY)
PROVIDER_WALLET_PRIVATE_KEY=

# ── Docker ─────────────────────────────────────────────────────────────────
DOCKER_HOST=tcp://localhost:2375

# ── Backend server ─────────────────────────────────────────────────────────
PORT=8080
# Subdomain used for deployed container workspaces (e.g. *.deploy.comput3.xyz)
DEPLOY_DOMAIN=

# ── Contract verification (Basescan) ───────────────────────────────────────
ETHERSCAN_API_KEY=

# ── Frontend (Next.js — copy relevant vars to frontend/.env.local) ─────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Fill from contracts/deployments.json after deploy-contracts.sh
NEXT_PUBLIC_PROVIDER_REGISTRY_ADDRESS=
NEXT_PUBLIC_DEPLOYMENT_ESCROW_ADDRESS=
NEXT_PUBLIC_JOB_AUCTION_ADDRESS=
